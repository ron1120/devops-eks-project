# Copy to .env in this directory and fill in values ( .env is gitignored ).
# cp .env.example .env
#
# Then run (sync Docker Hub + GitHub to AWS Secrets Manager):
#   ./export-env.sh

AWS_REGION=us-east-1

# Jenkins Elastic IP hidden elastic ip for ansible inventory
JENKINS_EIP=


# Docker Hub username
DOCKERHUB_USERNAME=
# Docker Hub password
DOCKERHUB_PASSWORD=
# Docker Hub secret ID on AWS Secrets Manager
AWS_DOCKERHUB_SECRET_ID=


# GitHub username
GIT_USERNAME=
# Fine grained access token with only the necessary permissions (no admin access)
GIT_API_TOKEN=''
# GitHub secret ID on AWS Secrets Manager
AWS_GIT_SECRET_ID=

# Slack Incoming Webhook URL (used by Jenkinsfile.* post.failure notifications)
# Generate one at https://api.slack.com/apps → Incoming Webhooks → Add New Webhook to Workspace.
SLACK_WEBHOOK_URL=''
# Slack secret ID on AWS Secrets Manager
AWS_SLACK_SECRET_ID=

# --- AWS for Jenkins CD (jenkins/Jenkinsfile.cd) ---
# The CD pipeline uses aws + kubectl on the Jenkins agent (EKS kubeconfig, ECR describe-images, apply k8s).
# Use the Jenkins EC2 IAM instance profile (see infrastructure/jenkins-master-aws/terraform/main.tf) — no Jenkins credential required.
# Only if you run a custom Pipeline that uses withCredentials(...'aws-credentials'...), create that Jenkins credential
# (Username + password: access key id + secret) or switch back to instance profile and drop withCredentials from the Jenkinsfile.
# Values below are for local documentation only—do not commit a filled .env.
# Leave these commented out to use your default AWS credential chain
# (~/.aws/credentials, AWS_PROFILE, SSO, instance role). Uncomment and set
# only if you want .env to force a specific key pair for the AWS CLI.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=