# Dockerfile for CLI tests

FROM python:3.12-slim
WORKDIR /workspace

# Copy the CLI, tests, and the data they reference
COPY cli/ cli/
COPY modules/ modules/
COPY workflows/ workflows/
COPY tests/cli/ tests/cli/

# Install the CLI requirements and pytest
RUN pip install --no-cache-dir -r cli/requirements.txt pytest

# Run both unit and integration tests
CMD ["pytest", "tests/cli/", "-v"]


### Can simply access locally the cli using:
### docker run -it cli-test:latest bash

### Build image using this dockerfile and main project directory:
### docker build -f Dockerfile.cli_test -t cli-test ..

# Run test image:
# docker run --rm cli-test