# Copy to .env in this directory and fill in values ( .env is gitignored ).
# cp .env.example .env
#
# Then run:
#   ./scripts/put-dockerhub-secret.sh

AWS_REGION=us-east-1
SECRET_ID=DockerHubCredentials

DOCKERHUB_USERNAME=
# Use quotes if the token contains # or spaces: DOCKERHUB_PASSWORD='dckr_pat_...'
DOCKERHUB_PASSWORD=

# --- AWS for Jenkins CD (jenkins/Jenkinsfile.cd) ---
# The CD pipeline uses aws + kubectl on the Jenkins agent (EKS kubeconfig, ECR describe-images, apply k8s).
# Use the Jenkins EC2 IAM instance profile (see infrastructure/jenkins-master-aws/terraform/main.tf) — no Jenkins credential required.
# Only if you run a custom Pipeline that uses withCredentials(...'aws-credentials'...), create that Jenkins credential
# (Username + password: access key id + secret) or switch back to instance profile and drop withCredentials from the Jenkinsfile.
# Values below are for local documentation only—do not commit a filled .env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: only when using temporary credentials (STS / assumed role)
# AWS_SESSION_TOKEN=
